# Environment Variables for NautilusTrader
# Copy this file to .env and update with your actual values

# ── Interactive Brokers (Live) ─────────────────────────────────────────────
TWS_USERNAME=your_ibkr_username
TWS_PASSWORD=your_ibkr_password
TWS_ACCOUNT=DU123456

# ── Interactive Brokers (Paper) ────────────────────────────────────────────
PAPER_TWS_USERNAME=your_paper_username
PAPER_TWS_PASSWORD=your_paper_password
PAPER_TWS_ACCOUNT=DU123456

# ── Polymarket ─────────────────────────────────────────────────────────────
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYMARKET_CHAIN_ID=137
POLYMARKET_FUNDER_ADDRESS=0x...
POLYMARKET_CLOB_API_KEY=...
POLYMARKET_ENV=prod
POLYMARKET_SIGNATURE_TYPE=1              # 0=direct EOA, 1=proxy wallet (recommended), 2=alt EIP-712

# ── Kraken (Spot) ──────────────────────────────────────────────────────────
KRAKEN_SPOT_API_KEY=...
KRAKEN_SPOT_API_SECRET=...

# ── Coinbase ───────────────────────────────────────────────────────────────
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_API_PASSPHRASE=
COINBASE_SANDBOX=true

# ── Binance ────────────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
